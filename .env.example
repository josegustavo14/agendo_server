# ============================================================
# Agendo - Variáveis de ambiente (Produção / VPS)
#
# Como usar:
#   1. Copie este arquivo para .env na mesma pasta:
#        cp .env.example .env
#   2. Preencha os valores reais no .env
#   3. Suba com:
#        docker compose -f docker-compose.prod.yml up -d --build
#
# IMPORTANTE: o .env (com valores reais) NÃO deve ir para o Git.
# Confirme que ".env" está no .gitignore. Este .env.example, sim,
# pode ser versionado (serve de modelo, sem segredos sensíveis).
# ============================================================

# ---------- Banco de dados (PostgreSQL) ----------
POSTGRES_DB=agendo_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=troque-esta-senha

# ---------- Datasource da aplicação (aponta para o container 'postgres') ----------
# O host é o nome do serviço no compose ('postgres'), não 'localhost'.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/agendo_db
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=troque-esta-senha

# ---------- JPA / Hibernate ----------
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_SHOW_SQL=false
SPRING_FORMAT_SQL=false

# ---------- Aplicação ----------
APP_SEED_ENABLED=false
APP_CORS_ALLOWED_ORIGINS=https://oortcloud.com.br

# ---------- Admin ----------
# Token compartilhado para endpoints administrativos (ex: POST /professions
# via curl). Gerar com: openssl rand -hex 32
AGENDO_ADMIN_TOKEN=troque-este-token

# ---------- AbacatePay ----------
# Projeto acadêmico em Dev mode: a api-key é a mesma de desenvolvimento.
ABACATEPAY_API_KEY=abc_dev_HguFzywEJpUrPuEYQhTKqCJY
# Secret do webhook "Oortcloud Produção" cadastrado no dashboard da AbacatePay.
ABACATEPAY_WEBHOOK_SECRET=de1f4e2252c75e56822534bd182cba3381a83d4530f79077ba6ab02f849f2797