# Copiar para .env e preencher valores reais antes do deploy
# NUNCA commitar .env

# PostgreSQL
POSTGRES_DB=agendo_db
POSTGRES_USER=agendo_user
# Gerar senha: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# Spring Datasource (deve coincidir com Postgres acima)
# ============================================================
# Agendo - Template de variáveis de ambiente
# Copiar para .env e preencher valores reais antes do deploy:
#   cp .env.example .env
# NUNCA commitar o arquivo .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=agendo_db
POSTGRES_USER=agendo_user
# Gerar senha forte: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# --- Spring Datasource (deve coincidir com os valores do Postgres acima) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/agendo_db
SPRING_DATASOURCE_USERNAME=agendo_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# --- JPA / Logging ---
SPRING_SHOW_SQL=false
SPRING_FORMAT_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Seeds (sempre false em prod)
APP_SEED_ENABLED=false

# CORS: trocar pelo domínio do frontend quando existir
# --- Seeds (sempre false em produção) ---
APP_SEED_ENABLED=false

# --- CORS ---
# Trocar pelo domínio do frontend quando existir (ex: https://app.agendo.com)
APP_CORS_ALLOWED_ORIGINS=*
